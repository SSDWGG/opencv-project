# Copy this file to .env.deploy.local, then replace the values below.
# .env.deploy.local is intentionally ignored by git because it may contain private server details.

DEPLOY_SSH_HOST=example.com
DEPLOY_SSH_USER=root
DEPLOY_SSH_PORT=22
DEPLOY_REMOTE_DIR=/var/www/html/web-finger-detector

# Optional: omit this line to use your default ssh-agent / ~/.ssh config.
DEPLOY_SSH_KEY=~/.ssh/id_rsa
